{
  "name": "@utrecht/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "build": "prisma generate --schema=./prisma/schema.prisma",
    "generate": "dotenv -e ../../.env -- prisma generate",
    "push": "dotenv -e ../../.env -- prisma db push",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "seed:programs": "dotenv -e ../../.env -- tsx src/seed-programs.ts",
    "scrape-images": "dotenv -e ../../.env -- tsx src/scrape-images.ts",
    "scrape:wikimedia": "dotenv -e ../../.env -- tsx src/scrape-wikimedia.ts",
    "filter:wikimedia": "dotenv -e ../../.env -- tsx src/filter-wikimedia.ts",
    "check:urls": "dotenv -e ../../.env -- tsx src/check-urls.ts",
    "seed:additions": "dotenv -e ../../.env -- tsx src/seed-additions.ts",
    "daily-report": "dotenv -e ../../.env -- tsx src/daily-report.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "dotenv-cli": "^7.4.2"
  }
}
